# local-only backup of the portrait/logo reference images moved OUT of
# public/cover so localhost renders the same placeholders as the live site.
/.cover-local-photos/

# reference placeholders downloaded from koyama-sendai.org.
# IP boundary: real people's PHOTOS and third-party LOGOS/trademarks stay OUT of
# the public repo (swap in your own licensed media later). Only the decorative
# ILLUSTRATIONS below — no likeness, no trademark — are committed so the cover
# actually renders on Vercel.
/public/cover/*
!/public/cover/illust-top.png
!/public/cover/illust-bottom.png
!/public/cover/ref/
/public/cover/ref/*
!/public/cover/ref/813a385b365d6b5f411d8ca917240a35.png
!/public/cover/ref/c6f6a7efce7557f19bf6e066549b8df3.png
